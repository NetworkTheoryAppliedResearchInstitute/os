# Based on: seqsense/aports-ros-experimental (credited, SEQSENSE OSS contributors)
# Modified for: NTARI OS v1.5 — Cyclone DDS exclusive, musl-safe
#
# ros_core meta-package: installs the minimal ROS2 Jazzy communication graph.
# Installs: rcutils, rcl, rmw, rmw_cyclonedds_cpp, rclcpp, rclpy, ros2cli
#
# SPDX-License-Identifier: Apache-2.0

pkgname=ros2-jazzy-ros-core
pkgver=0.11.0
pkgrel=1
pkgdesc="ROS2 Jazzy ros_core — minimal DDS communication graph (Cyclone DDS, musl)"
url="https://www.ros.org"
arch="x86_64 aarch64 armv7"
license="Apache-2.0"
makedepends="
    cmake
    samurai
    python3-dev
    py3-setuptools
    py3-wheel
    tinyxml2-dev
    libyaml-dev
    openssl-dev
    asio-dev
    cyclonedds-dev
    ros2-jazzy-ament-cmake
    ros2-jazzy-rcutils
    ros2-jazzy-rcl-interfaces
    ros2-jazzy-rmw
    ros2-jazzy-rosidl
"
depends="
    cyclonedds
    python3
    py3-yaml
    py3-netifaces
    libyaml
    tinyxml2
"
subpackages="$pkgname-dev $pkgname-doc"

# ros_core is built as a colcon workspace — individual packages below
# Point to the unified ros2.repos for Jazzy pinned versions
source="
    https://raw.githubusercontent.com/ros2/ros2/jazzy/ros2.repos
"
builddir="$srcdir/ros2_ws"

sha256sums="SKIP"

# ── Package list for ros_core ─────────────────────────────────────────────
# This APKBUILD pulls the minimal set of packages required to:
#   1. Start a ROS2 Jazzy node
#   2. Create topics and services
#   3. Use rclcpp (C++) and rclpy (Python)
#   4. Use Cyclone DDS as the RMW
#
# Order of build dependencies (must build in this sequence):
_ros_core_pkgs="
    ament/ament_cmake
    ament/ament_package
    ament/ament_cmake_core
    ament/ament_cmake_python
    ros2/rcutils
    ros2/rcl_interfaces
    ros2/rmw
    ros2/rmw_cyclonedds_cpp
    ros2/rcl
    ros2/rclcpp
    ros2/rclpy
    ros2/ros2cli
    ros2/ros_workspace
"

prepare() {
    mkdir -p "$builddir/src"

    # Use vcs to import only ros_core packages from ros2.repos
    # In practice: clone each individually at pinned Jazzy SHA
    # Full vcs import would pull 300+ repos — not needed for ros_core

    msg "Importing ros_core packages from ros2.repos"
    # vcs import --shallow --input "$srcdir/ros2.repos" "$builddir/src" \
    #     --filter "$_ros_core_pkgs"
    #
    # NOTE: The above command requires 'vcstool' (py3-vcstool APK).
    # For the NTARI OS build, the build script (build/ros2-build.sh)
    # handles the vcs import step and passes the pre-populated source tree
    # into this APKBUILD via APORTSDIR.
    #
    # See: build/ros2-build.sh → step: "Import ros_core packages"
}

build() {
    cd "$builddir"

    # Force Cyclone DDS as exclusive RMW — do not build Fast-DDS
    export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

    # musl-specific: disable ASan/TSan (not available on musl)
    # Use UBSan trap-only mode for build validation
    export CFLAGS="$CFLAGS -fsanitize-undefined-trap-on-error"
    export CXXFLAGS="$CXXFLAGS -fsanitize-undefined-trap-on-error"

    colcon build \
        --merge-install \
        --install-base /opt/ros/jazzy \
        --cmake-args \
            -DCMAKE_BUILD_TYPE=Release \
            -DCMAKE_INSTALL_PREFIX=/opt/ros/jazzy \
            -DRMW_IMPLEMENTATION=rmw_cyclonedds_cpp \
            -DBUILD_TESTING=OFF \
        --packages-select \
            ament_cmake \
            ament_package \
            rcutils \
            rcl_interfaces \
            rmw \
            rmw_cyclonedds_cpp \
            rcl \
            rclcpp \
            rclpy \
            ros2cli \
            ros_workspace
}

check() {
    # Basic sanity: source setup.sh and verify ros2 CLI responds
    . /opt/ros/jazzy/setup.sh
    ros2 --help >/dev/null && echo "ros2 CLI: OK"
    python3 -c "import rclpy; print('rclpy: OK')"
}

package() {
    # colcon builds into /opt/ros/jazzy directly
    # Package the entire install tree
    mkdir -p "$pkgdir/opt/ros"
    cp -a /opt/ros/jazzy "$pkgdir/opt/ros/jazzy"

    # Profile.d entry so users get ROS2 env on login
    install -Dm644 /dev/stdin \
        "$pkgdir/etc/profile.d/ros2-jazzy.sh" <<'EOF'
# ROS2 Jazzy environment — NTARI OS
if [ -f /opt/ros/jazzy/setup.sh ]; then
    . /opt/ros/jazzy/setup.sh
fi
export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-0}"
EOF

    install -Dm644 /dev/stdin \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE" <<'EOF'
Apache License 2.0 — see https://www.ros.org for details.
EOF
}
