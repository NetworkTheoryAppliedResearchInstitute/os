# Maintainer: NTARI <contact@ntari.org>
pkgname=soholink
pkgver=0.1.0
pkgrel=0
pkgdesc="Federated Edge AAA Platform"
url="https://github.com/NetworkTheoryAppliedResearchInstitute/soholink"
arch="x86_64 aarch64"
license="AGPL-3.0"
depends="ca-certificates sqlite"
makedepends="go"
source="soholink-$pkgver.tar.gz"
builddir="$srcdir/soholink-$pkgver"

build() {
	cd "$builddir"
	CGO_ENABLED=0 go build -o fedaaa \
		-ldflags "-s -w -X main.Version=$pkgver" \
		./cmd/fedaaa
}

check() {
	cd "$builddir"
	go test ./...
}

package() {
	cd "$builddir"
	install -Dm755 fedaaa "$pkgdir"/usr/bin/fedaaa
	install -Dm644 config.yaml "$pkgdir"/etc/soholink/config.yaml
	install -Dm644 LICENSE.txt "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}
