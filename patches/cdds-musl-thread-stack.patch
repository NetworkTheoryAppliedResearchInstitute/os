  *
@@ -20,6 +39,22 @@
 #include "dds/ddsrt/threads_priv.h"
 #include "dds/ddsrt/string.h"

+/* ── musl thread stack size fix ─────────────────────────────────────────── */
+/* musl libc default thread stack = 128 KB; glibc default = ~2–8 MB.        */
+/* DDS serialization/discovery threads need at least 512 KB; set 2 MB       */
+/* to match glibc behaviour and provide headroom for complex message types.  */
+#if defined(__linux__) && !defined(__GLIBC__)
+#  define NTARI_MUSL_STACK_SIZE (2 * 1024 * 1024)  /* 2 MB */
+#  define NTARI_MUSL_PATCH 1
+#endif
+
+static void ddsrt_thread_apply_musl_stack(pthread_attr_t *attr)
+{
+#ifdef NTARI_MUSL_PATCH
+    size_t stacksize = 0;
+    pthread_attr_getstacksize(attr, &stacksize);
+    if (stacksize < NTARI_MUSL_STACK_SIZE) {
+        pthread_attr_setstacksize(attr, NTARI_MUSL_STACK_SIZE);
+    }
+#else
+    (void)attr;
+#endif
+}
+
