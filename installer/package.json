{
  "name": "ntari-installer",
  "version": "1.3.0",
  "description": "Cross-platform USB installer for NTARI OS",
  "author": "Network Theory Applied Research Institute",
  "license": "AGPL-3.0",
  "main": "src/main/main.js",
  "homepage": "https://ntari.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/NetworkTheoryAppliedResearchInstitute/ntari-os.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --win --mac --linux",
    "build:windows": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "preview": "electron-vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write 'src/**/*.{js,jsx,json,css}'"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "electron-updater": "^6.1.8",
    "etcher-sdk": "^8.0.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "usb": "^2.11.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "playwright": "^1.41.2",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "vitest": "^1.2.2"
  },
  "build": {
    "appId": "org.ntari.installer",
    "productName": "NTARI Installer",
    "copyright": "Copyright © 2026 Network Theory Applied Research Institute",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
